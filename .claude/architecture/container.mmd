%% Container level (C4 L2): major runtime pieces inside the node.
%% Last updated: 2026-07-21 (Nexus removed; TTS removed from core)
flowchart TB
    subgraph Scheduler["Scheduler (systemd)"]
        NT[night-agent.timer\nnightly windows]
        ET[emergency-agent.timer\ndaytime override]
        MT[session_trigger_server.py\nport 8766 — manual]
    end

    subgraph ExecPipeline["Execution Pipeline"]
        WS[wake.sh\ngates + pre-launch]
        ST[resolve_session_type.py\nexecution / planning /\nmaintenance / philosophy]
        CL[claude -p\nwrapper_prompt.md]
        WS --> ST --> CL
    end

    subgraph ConvLayer["Conversational Layer (optional)"]
        CVS[conversation.sh\nwebhook mgmt + restart loop]
        TW[telegram_watcher.py\ngetUpdates long-poll]
        CD[command_dispatcher.py\n/status /report /goal etc]
        CVS --> TW --> CD
    end

    subgraph Memory["Memory & State"]
        MEM[memory/\nlatest_summary progress\nlearnings sessions work/]
        STATE[state/\nbehavioral_context\nloom_context reports/]
        INBOX[inbox/pending.json\nconv→exec handoff]
        LOGS[logs/\nwake.log session_log.csv\nanalytics.db]
        SCHED[config/session_schedule.json\nactive window config]
    end

    subgraph Integrations["Integrations"]
        LOOM[(Loom DB\nrequired)]
        TG[(Telegram API\noptional)]
    end

    NT --> WS
    ET --> WS
    MT --> WS

    CL --> MEM
    CL --> STATE
    CL --> LOGS
    CL --> LOOM

    TW --> INBOX
    CL --> INBOX

    TW --> TG
