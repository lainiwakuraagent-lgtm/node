%% Component: pre-session gate tools — checks run by wake.sh before launching Claude.
%% These are read-only checks; none modify state. All are non-fatal (fail-open).
flowchart TD
    WS[wake.sh\nlauncher]

    subgraph Gates["Gate checks (pre-launch)"]
        CU[check_usage.sh\nGate 0 — reads Claude API\nusage via claude /status\nAborts if limit exceeded]
        CT[check_time.sh\ntime window awareness\nreports remaining minutes\nfor agent self-pacing]
        CC[check_context.sh\ncontext window estimate\nfrom log file size\nused mid-session too]
    end

    subgraph Inbox["Inbox processing (session start)"]
        IS[inbox_startup.py\nreads inbox/pending.json\ncreates Loom tasks from\ntask_request entries]
        IR[inbox_read.py\nread + prune entries\n--prune removes >7d old]
        IA[inbox_append.py\nwrite new entry to\npending.json — used by conv layer]
    end

    WS -->|Gate 0| CU
    WS -->|informational| CT
    WS -->|post-orient| CC
    WS -->|session start| IS
    IS --> IR
